# Optional: override defaults
# SECRET_KEY=your-secret-key
# DATABASE_URL=sqlite+aiosqlite:///./winlytics.db

# Production: comma-separated frontend URLs for CORS (e.g. https://winlytics.vercel.app)
# CORS_ORIGINS=https://winlytics.vercel.app

# Google Sign-In: same value as frontend NEXT_PUBLIC_GOOGLE_CLIENT_ID (see docs/GOOGLE-SIGNIN-SETUP.md)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
